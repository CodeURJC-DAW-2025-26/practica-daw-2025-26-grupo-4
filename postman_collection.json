{
  "info": {
    "name": "DAW Spring API",
    "description": "API REST Endpoints para el proyecto DAW",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api"
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/products/"
          },
          "response": []
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/1",
              "host": ["{{base_url}}"],
              "path": ["products", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Producto\",\n  \"description\": \"Descripcion del producto\"\n}"
            },
            "url": "{{base_url}}/products/"
          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Producto Actualizado\",\n  \"description\": \"Descripcion actualizada\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/products/1",
              "host": ["{{base_url}}"],
              "path": ["products", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/1",
              "host": ["{{base_url}}"],
              "path": ["products", "1"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get All Reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/reviews/"
          },
          "response": []
        },
        {
          "name": "Get Review by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reviews/1",
              "host": ["{{base_url}}"],
              "path": ["reviews", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Excelente producto\",\n  \"rating\": 5\n}"
            },
            "url": "{{base_url}}/reviews/"
          },
          "response": []
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Modifico la review, es bueno\",\n  \"rating\": 4\n}"
            },
            "url": {
              "raw": "{{base_url}}/reviews/1",
              "host": ["{{base_url}}"],
              "path": ["reviews", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reviews/1",
              "host": ["{{base_url}}"],
              "path": ["reviews", "1"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get User Cart",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/cart/"
          },
          "response": []
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart/items/1?quantity=1",
              "host": ["{{base_url}}"],
              "path": ["cart", "items", "1"],
              "query": [
                {
                  "key": "quantity",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart/items/1",
              "host": ["{{base_url}}"],
              "path": ["cart", "items", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/cart/"
          },
          "response": []
        },
        {
          "name": "Checkout Cart",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/cart/checkout"
          },
          "response": []
        }
      ]
    }
  ]
}
